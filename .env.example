ENV=development
LOG_LEVEL=INFO

SECRET_KEY=change-me-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Local Postgres:
#   DATABASE_URL=postgresql+asyncpg://simulafly:simulafly@localhost:5432/simulafly
# Neon (use the pooler URL, convert sslmode=require -> ssl=require, drop channel_binding):
#   DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST-pooler.REGION.aws.neon.tech/DB?ssl=require
DATABASE_URL=postgresql+asyncpg://simulafly:simulafly@localhost:5432/simulafly

AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
AZURE_CHAT_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_IMAGE_EDIT_DEPLOYMENT=gpt-image-1
AZURE_IMAGE_GEN_DEPLOYMENT=

ALLOWED_ORIGINS=*

# CSV of accepted Google OAuth client IDs (`aud` of the ID token).
# Include the Android OAuth client ID AND the Web OAuth client ID
# (the Flutter client uses the Web one as `serverClientId`).
GOOGLE_CLIENT_IDS=

RATE_LIMIT_PER_MINUTE=60
CHAT_RATE_LIMIT_PER_MINUTE=20
IMAGE_GEN_RATE_LIMIT_PER_HOUR=10
UPLOAD_RATE_LIMIT_PER_HOUR=30

MAX_IMAGE_BYTES=5242880
MAX_REQUEST_BYTES=8388608

# Shared secret for /styles admin endpoints (POST/PATCH/DELETE).
# Empty = admin endpoints disabled. Generate with `openssl rand -hex 32`.
ADMIN_API_KEY=

RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
